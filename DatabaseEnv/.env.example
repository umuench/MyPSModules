# ==================================
# MASTER VORLAGE (Beispiel)
# ==================================

# --- MySQL (Standard-Instanz) ---
DB_MYSQL_HOST=localhost
DB_MYSQL_PORT=3306
DB_MYSQL_USER_DEFAULT=dbuser
DB_MYSQL_PASS_DEFAULT="CHANGE_ME"
# Spezifische Benutzer (optional)
DB_MYSQL_USER_UMUENCH=umuench
DB_MYSQL_PASS_UMUENCH="CHANGE_ME"

# --- MariaDB (Zweite Instanz) ---
DB_MARIADB_HOST=localhost
DB_MARIADB_PORT=3307
DB_MARIADB_USER_DEFAULT=dbuser
DB_MARIADB_PASS_DEFAULT="CHANGE_ME"
# Spezifische Benutzer (optional)
DB_MARIADB_USER_UMUENCH=umuench
DB_MARIADB_PASS_UMUENCH="CHANGE_ME"

# --- PostgreSQL ---
DB_POSTGRESQL_HOST=localhost
DB_POSTGRESQL_PORT=5432
DB_POSTGRESQL_USER_DEFAULT=dbuser
DB_POSTGRESQL_PASS_DEFAULT="CHANGE_ME"
# Spezifische Benutzer (optional)
DB_POSTGRESQL_USER_UMUENCH=umuench
DB_POSTGRESQL_PASS_UMUENCH="CHANGE_ME"
# Weitere Instanz/Benutzer (Beispiel)
# DB_POSTGRESQL_USER_APP=appuser
# DB_POSTGRESQL_PASS_APP="CHANGE_ME"
#
# Profil-Option (Variante 1: system-spezifische Suffixe)
# DB_POSTGRESQL_PROFILE=REPLICA
# DB_POSTGRESQL_HOST_REPLICA=localhost
# DB_POSTGRESQL_PORT_REPLICA=5433
# DB_POSTGRESQL_USER_DEFAULT_REPLICA=replica_user
# DB_POSTGRESQL_PASS_DEFAULT_REPLICA="CHANGE_ME"
# DB_POSTGRESQL_PASS_UMUENCH_REPLICA="CHANGE_ME"
#
# Profil-Option (Variante 2: globale Suffixe)
# DB_PROFILE=STAGING
# DB_HOST_STAGING=staging.db.local
# DB_PORT_STAGING=5432
# DB_USER_DEFAULT_STAGING=staging_user
# DB_PASS_DEFAULT_STAGING="CHANGE_ME"
# DB_PASS_UMUENCH_STAGING="CHANGE_ME"

# --- MSSQL ---
DB_MSSQL_HOST=localhost
DB_MSSQL_PORT=1433
DB_MSSQL_USER_DEFAULT=dbuser
DB_MSSQL_PASS_DEFAULT="CHANGE_ME"
# Spezifische Benutzer (optional)
DB_MSSQL_USER_UMUENCH=umuench
DB_MSSQL_PASS_UMUENCH="CHANGE_ME"
# Weitere Instanz/Benutzer (Beispiel)
# DB_MSSQL_USER_APP=appuser
# DB_MSSQL_PASS_APP="CHANGE_ME"
#
# Profil-Option (Variante 1: system-spezifische Suffixe)
# DB_MSSQL_PROFILE=REPLICA
# DB_MSSQL_HOST_REPLICA=localhost
# DB_MSSQL_PORT_REPLICA=1434
# DB_MSSQL_USER_DEFAULT_REPLICA=replica_user
# DB_MSSQL_PASS_DEFAULT_REPLICA="CHANGE_ME"
# DB_MSSQL_PASS_UMUENCH_REPLICA="CHANGE_ME"
#
# Profil-Option (Variante 2: globale Suffixe)
# DB_PROFILE=STAGING
# DB_HOST_STAGING=staging.db.local
# DB_PORT_STAGING=1433
# DB_USER_DEFAULT_STAGING=staging_user
# DB_PASS_DEFAULT_STAGING="CHANGE_ME"
# DB_PASS_UMUENCH_STAGING="CHANGE_ME"
